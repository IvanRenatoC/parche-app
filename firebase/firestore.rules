rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: usuario autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: uid del usuario autenticado
    function uid() {
      return request.auth.uid;
    }

    // Helper: el usuario es dueño del recurso por uid
    function isOwner(resourceUid) {
      return isAuthenticated() && uid() == resourceUid;
    }

    // Helper: leer el rol del usuario desde users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isOwnerRole() {
      return isAuthenticated() && getUserRole() == 'owner';
    }

    function isWorkerRole() {
      return isAuthenticated() && getUserRole() == 'worker';
    }

    // ───────────────────────────────────────────────
    // users/{uid}
    // ───────────────────────────────────────────────
    // MVP: lectura para cualquier autenticado para que el owner pueda ver el
    // perfil del postulante (nombre, email, RUT) y el worker pueda ver datos
    // públicos del owner si fuera necesario. Trade-off documentado en
    // docs/SECURITY_RULES.md — escritura sigue restringida al dueño.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // owners/{uid}
    // ───────────────────────────────────────────────
    match /owners/{ownerId} {
      allow read: if isOwner(ownerId);
      allow create: if isOwner(ownerId);
      allow update: if isOwner(ownerId);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // workers/{uid}
    // ───────────────────────────────────────────────
    // MVP: lectura para cualquier autenticado para que el owner pueda ver
    // oficios, años de experiencia y nacionalidad del postulante en el
    // resumen del modal. Documentos sensibles (foto carnet, certificados)
    // siguen en Storage con sus propias reglas.
    match /workers/{workerId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(workerId);
      allow update: if isOwner(workerId);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // businesses/{businessId}
    // ───────────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if isAuthenticated() && resource.data.owner_uid == uid();
      allow create: if isAuthenticated()
                    && request.resource.data.owner_uid == uid();
      allow update: if isAuthenticated() && resource.data.owner_uid == uid();
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // job_posts/{jobPostId}
    // ───────────────────────────────────────────────
    match /job_posts/{jobPostId} {
      // Workers pueden ver publicaciones publicadas; owners ven las suyas
      allow read: if isAuthenticated()
                  && (resource.data.status == 'published'
                      || resource.data.owner_uid == uid());
      allow create: if isAuthenticated()
                    && request.resource.data.owner_uid == uid();
      allow update: if isAuthenticated() && resource.data.owner_uid == uid();
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // applications/{applicationId}
    // ───────────────────────────────────────────────
    match /applications/{applicationId} {
      // Worker ve sus propias postulaciones; owner ve las de sus publicaciones
      allow read: if isAuthenticated()
                  && (resource.data.worker_uid == uid()
                      || resource.data.owner_uid == uid());
      // Worker crea su propia postulación
      allow create: if isAuthenticated()
                    && request.resource.data.worker_uid == uid();
      // Worker puede retirar; backend maneja aceptar/rechazar/not_selected
      allow update: if isAuthenticated() && resource.data.worker_uid == uid()
                    && request.resource.data.status == 'withdrawn'
                    && resource.data.status == 'applied';
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // comments/{commentId}
    // ───────────────────────────────────────────────
    match /comments/{commentId} {
      // Cualquier usuario autenticado puede leer comentarios de publicaciones visibles
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.author_uid == uid();
      // Solo el autor puede editar/borrar su comentario
      allow update: if isAuthenticated() && resource.data.author_uid == uid();
      allow delete: if isAuthenticated() && resource.data.author_uid == uid();
    }

    // ───────────────────────────────────────────────
    // ratings/{ratingId}
    // ───────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if isAuthenticated()
                  && (resource.data.from_uid == uid()
                      || resource.data.to_uid == uid());
      allow create: if isAuthenticated()
                    && request.resource.data.from_uid == uid()
                    && request.resource.data.from_uid != request.resource.data.to_uid;
      allow update: if false;
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // notifications/{notificationId}
    // ───────────────────────────────────────────────
    // Modelo: las notificaciones pueden ser directas (recipient_uid != '')
    // o broadcast por rol (recipient_role != ''). Las broadcast usan read_by[]
    // para que cada usuario marque como leída individualmente.
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
                  && (resource.data.recipient_uid == uid()
                      || (resource.data.recipient_role != ''
                          && resource.data.recipient_role == getUserRole()));
      // Cualquier usuario autenticado puede crear notificaciones para otros
      // (un worker notifica al owner al postular/desistir; un owner notifica
      // a los workers al publicar). El recipient_uid no puede ser uno mismo.
      allow create: if isAuthenticated()
                    && request.resource.data.recipient_uid is string
                    && request.resource.data.recipient_role is string
                    && request.resource.data.recipient_uid != uid();
      // Marcar como leída: 'read' para directas, 'read_by' para broadcast.
      allow update: if isAuthenticated()
                    && (resource.data.recipient_uid == uid()
                        || (resource.data.recipient_role != ''
                            && resource.data.recipient_role == getUserRole()))
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'read_by']);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // chats/{chatId}  +  chats/{chatId}/messages/{msgId}
    // ───────────────────────────────────────────────
    // Solo los dos participantes (owner + worker) pueden leer y escribir.
    // Usamos campos escalares owner_uid / worker_uid (en vez de participants[])
    // para que las queries con where() sean compatibles con las reglas.
    match /chats/{chatId} {
      allow read: if isAuthenticated()
                  && (resource.data.owner_uid == uid()
                      || resource.data.worker_uid == uid());
      allow create: if isAuthenticated()
                    && (request.resource.data.owner_uid == uid()
                        || request.resource.data.worker_uid == uid());
      allow update: if isAuthenticated()
                    && (resource.data.owner_uid == uid()
                        || resource.data.worker_uid == uid())
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['last_message', 'last_message_at', 'updated_at']);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
                    && (get(/databases/$(database)/documents/chats/$(chatId)).data.owner_uid == uid()
                        || get(/databases/$(database)/documents/chats/$(chatId)).data.worker_uid == uid());
        allow create: if isAuthenticated()
                      && (get(/databases/$(database)/documents/chats/$(chatId)).data.owner_uid == uid()
                          || get(/databases/$(database)/documents/chats/$(chatId)).data.worker_uid == uid())
                      && request.resource.data.sender_uid == uid()
                      && request.resource.data.content is string
                      && request.resource.data.content.size() > 0;
        allow update, delete: if false;
      }
    }

    // ───────────────────────────────────────────────
    // audit_logs/{logId}
    // ───────────────────────────────────────────────
    match /audit_logs/{logId} {
      // Solo el backend (Admin SDK) puede leer/escribir audit_logs
      allow read: if false;
      allow write: if false;
    }
  }
}
