rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: usuario autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: uid del usuario autenticado
    function uid() {
      return request.auth.uid;
    }

    // Helper: el usuario es dueño del recurso por uid
    function isOwner(resourceUid) {
      return isAuthenticated() && uid() == resourceUid;
    }

    // Helper: leer el rol del usuario desde users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isOwnerRole() {
      return isAuthenticated() && getUserRole() == 'owner';
    }

    function isWorkerRole() {
      return isAuthenticated() && getUserRole() == 'worker';
    }

    // ───────────────────────────────────────────────
    // users/{uid}
    // ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // owners/{uid}
    // ───────────────────────────────────────────────
    match /owners/{ownerId} {
      allow read: if isOwner(ownerId);
      allow create: if isOwner(ownerId);
      allow update: if isOwner(ownerId);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // workers/{uid}
    // ───────────────────────────────────────────────
    match /workers/{workerId} {
      allow read: if isOwner(workerId);
      allow create: if isOwner(workerId);
      allow update: if isOwner(workerId);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // businesses/{businessId}
    // ───────────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if isAuthenticated() && resource.data.owner_uid == uid();
      allow create: if isAuthenticated()
                    && request.resource.data.owner_uid == uid();
      allow update: if isAuthenticated() && resource.data.owner_uid == uid();
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // job_posts/{jobPostId}
    // ───────────────────────────────────────────────
    match /job_posts/{jobPostId} {
      // Workers pueden ver publicaciones publicadas; owners ven las suyas
      allow read: if isAuthenticated()
                  && (resource.data.status == 'published'
                      || resource.data.owner_uid == uid());
      allow create: if isAuthenticated()
                    && request.resource.data.owner_uid == uid();
      allow update: if isAuthenticated() && resource.data.owner_uid == uid();
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // applications/{applicationId}
    // ───────────────────────────────────────────────
    match /applications/{applicationId} {
      // Worker ve sus propias postulaciones; owner ve las de sus publicaciones
      allow read: if isAuthenticated()
                  && (resource.data.worker_uid == uid()
                      || resource.data.owner_uid == uid());
      // Worker crea su propia postulación
      allow create: if isAuthenticated()
                    && request.resource.data.worker_uid == uid();
      // Worker puede retirar; backend maneja aceptar/rechazar/not_selected
      allow update: if isAuthenticated() && resource.data.worker_uid == uid()
                    && request.resource.data.status == 'withdrawn'
                    && resource.data.status == 'applied';
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // comments/{commentId}
    // ───────────────────────────────────────────────
    match /comments/{commentId} {
      // Cualquier usuario autenticado puede leer comentarios de publicaciones visibles
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.author_uid == uid();
      // Solo el autor puede editar/borrar su comentario
      allow update: if isAuthenticated() && resource.data.author_uid == uid();
      allow delete: if isAuthenticated() && resource.data.author_uid == uid();
    }

    // ───────────────────────────────────────────────
    // ratings/{ratingId}
    // ───────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if isAuthenticated()
                  && (resource.data.from_uid == uid()
                      || resource.data.to_uid == uid());
      allow create: if isAuthenticated()
                    && request.resource.data.from_uid == uid()
                    && request.resource.data.from_uid != request.resource.data.to_uid;
      allow update: if false;
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // notifications/{notificationId}
    // ───────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipient_uid == uid();
      // Solo backend puede crear notificaciones; usuario solo puede marcar como leída
      allow create: if false;
      allow update: if isAuthenticated()
                    && resource.data.recipient_uid == uid()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    // ───────────────────────────────────────────────
    // audit_logs/{logId}
    // ───────────────────────────────────────────────
    match /audit_logs/{logId} {
      // Solo el backend (Admin SDK) puede leer/escribir audit_logs
      allow read: if false;
      allow write: if false;
    }
  }
}
